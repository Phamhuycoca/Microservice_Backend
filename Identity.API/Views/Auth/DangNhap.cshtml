@model Identity.API.Models.DangNhapViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đăng nhập</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <style>
        body {
            margin: 0;
            overflow: hidden;
            background: #f4f7fb;
            font-family: Arial, Helvetica, sans-serif;
        }

        .login-wrapper {
            height: 100vh;
        }

        .left-side {
            position: relative;
            background: linear-gradient(to bottom, #0052cc, #003b99);
            color: white;
            overflow: hidden;
        }

        .circle-1 {
            position: absolute;
            width: 500px;
            height: 500px;
            background: rgba(59,130,246,0.2);
            border-radius: 50%;
            left: -180px;
            bottom: -180px;
        }

        .circle-2 {
            position: absolute;
            width: 300px;
            height: 300px;
            background: rgba(255,255,255,0.05);
            border-radius: 50%;
            top: -100px;
            left: -100px;
        }

        .dots {
            position: absolute;
            top: 30px;
            left: 30px;
            display: grid;
            grid-template-columns: repeat(8, 1fr);
            gap: 10px;
            opacity: 0.3;
        }

        .dot {
            width: 4px;
            height: 4px;
            background: white;
            border-radius: 50%;
        }

        .left-content {
            position: relative;
            z-index: 10;
            text-align: center;
        }

            .left-content img {
                width: 260px;
            }

            .left-content h1 {
                margin-top: 30px;
                margin-bottom: 15px;
                font-size: 42px;
                font-weight: 700;
            }

            .left-content p {
                font-size: 18px;
                opacity: 0.9;
            }

        .right-side {
            background: white;
            padding: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-box {
            width: 100%;
            max-width: 520px;
        }

        .logo {
            text-align: center;
            margin-bottom: 30px;
        }

            .logo img {
                width: 180px;
            }

        .title {
            text-align: center;
            margin-bottom: 40px;
        }

            .title h2 {
                font-size: 42px;
                font-weight: bold;
            }

            .title p {
                color: #6b7280;
                font-size: 16px;
            }

        .form-control {
            height: 52px;
            border-radius: 12px !important;
        }

        .input-group-text {
            border-radius: 12px 0 0 12px;
        }

        .login-btn {
            height: 52px;
            border-radius: 12px;
            background: #0052cc;
            border: none;
            font-size: 16px;
            font-weight: 600;
        }

            .login-btn:hover {
                background: #003b99;
            }

        .footer {
            text-align: center;
            color: #9ca3af;
            margin-top: 30px;
        }

        .field-validation-error {
            color: red;
            font-size: 14px;
        }

        .input-validation-error {
            border: 1px solid red !important;
        }

        .validation-summary-errors {
            color: red;
            margin-bottom: 16px;
        }
    </style>
</head>
<body>

    <div class="container-fluid login-wrapper">
        <div class="row h-100">

            <!-- LEFT -->
            <div class="col-md-6 left-side d-flex align-items-center justify-content-center">

                <div class="circle-1"></div>
                <div class="circle-2"></div>

                <div class="dots">
                    @for (int i = 0; i < 64; i++)
                    {
                        <div class="dot"></div>
                    }
                </div>

                <div class="left-content">

                    <img src="~/images/logo_1.png" alt="logo" />

                    <h1>HR Management System</h1>

                    <p>Quản trị nhân sự hiệu quả</p>

                    <p>Phát triển tổ chức bền vững</p>

                </div>
            </div>

            <!-- RIGHT -->
            <div class="col-md-6 right-side">

                <div class="login-box">

                    <!-- LOGO -->
                    <div class="logo">
                        <img src="~/images/logo.png" alt="logo" />
                    </div>

                    <!-- TITLE -->
                    <div class="title">
                        <h2>Đăng nhập</h2>
                        <p>Chào mừng bạn quay trở lại!</p>
                    </div>

                    <!-- FORM -->
                    <form asp-controller="Auth"
                          asp-action="DangNhap"
                          method="post">

                        <!-- validation summary -->
                        <div asp-validation-summary="ModelOnly"
                             class="validation-summary-errors">
                        </div>

                        <!-- USERNAME -->
                        <div class="mb-4">

                            <label asp-for="tai_khoan"
                                   class="form-label">
                                Tên đăng nhập
                            </label>

                            <div class="input-group">

                                <span class="input-group-text">
                                    <i class="fa fa-user"></i>
                                </span>

                                <input asp-for="tai_khoan"
                                       class="form-control"
                                       placeholder="Nhập tên đăng nhập" />

                            </div>

                            <span asp-validation-for="tai_khoan"
                                  class="field-validation-error">
                            </span>

                        </div>

                        <!-- PASSWORD -->
                        <div class="mb-4">

                            <label asp-for="mat_khau"
                                   class="form-label">
                                Mật khẩu
                            </label>

                            <div class="input-group">

                                <span class="input-group-text">
                                    <i class="fa fa-lock"></i>
                                </span>

                                <input asp-for="mat_khau"
                                       type="password"
                                       class="form-control"
                                       placeholder="Nhập mật khẩu" />

                            </div>

                            <span asp-validation-for="mat_khau"
                                  class="field-validation-error">
                            </span>

                        </div>

                        <!-- REMEMBER -->
                        <div class="d-flex justify-content-between mb-4">

                            <div class="form-check">

                                <input asp-for="RememberMe"
                                       class="form-check-input" />

                                <label asp-for="RememberMe"
                                       class="form-check-label">
                                    Nhớ tài khoản
                                </label>

                            </div>

                            <a href="#">
                                Quên mật khẩu?
                            </a>

                        </div>

                        <!-- BUTTON -->
                        <button type="submit"
                                class="btn btn-primary w-100 login-btn">
                            Đăng nhập
                        </button>

                        <hr class="my-4" />

                        <div class="text-center text-secondary">
                            Bạn cần trợ giúp truy cập tài khoản?
                            <a href="#">
                                Vui lòng liên hệ bộ phận hỗ trợ IT
                            </a>
                        </div>

                    </form>

                    <div class="footer">
                        © 2026 HRM System. All rights reserved.
                    </div>

                </div>

            </div>

        </div>
    </div>

    <!-- Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- jQuery -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

    <!-- Validation -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation/1.19.5/jquery.validate.min.js"></script>

    <!-- Unobtrusive -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>